{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "strict": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["deploy/**/*.ts", "app/src/**/*.ts", "app/src/**/*.tsx"]
}

